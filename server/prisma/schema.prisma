generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AvailabilityRequest {
  id           String   @id @default(uuid())
  need         String?
  imageUrl     String?
  locale       String?
  sessionToken String?
  createdAt    DateTime @default(now())
}

model Admin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  sessionToken String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hospitalChatSessions AdminHospitalChatSession[]
}

model AdminHospitalChatSession {
  id        String   @id @default(uuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  AdminHospitalChatMessage[]

  @@index([adminId])
}

model AdminHospitalChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  session   AdminHospitalChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([sessionId])
}

model Hospital {
  id             String            @id @default(uuid())
  name           String            @unique
  city           String?
  country        String?
  address        String?
  phone          String?
  email          String?
  website        String?
  emergency24h   Boolean?
  bedCount       Int?
  latitude       Float?
  longitude      Float?
  averageWaitDays Int?
  isActive       Boolean           @default(true)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  services       HospitalService[]
  appointmentRequests AppointmentRequest[]
}

model HospitalService {
  id               String    @id @default(uuid())
  hospitalId       String
  specialty        String?
  procedureName    String?
  estimatedWaitDays Int?
  earliestDate     DateTime?
  isActive         Boolean   @default(true)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  hospital         Hospital  @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([hospitalId])
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String?
  password     String
  sessionToken String?  @unique
  /// "free" | "pro". Null = legacy account (treated as free).
  subscriptionPlan        String?
  subscriptionStartedAt DateTime?
  subscriptionEndsAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appointmentRequests AppointmentRequest[]
}

model AppointmentRequest {
  id            String   @id @default(uuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email         String
  query         String
  intent        String?
  city          String?
  hospitalId    String?
  hospitalName  String?
  preferredDate DateTime
  /** Legacy alias; kept in sync with notifySms on create */
  notifyWhenAvailable Boolean @default(false)
  notifyEmail           Boolean @default(true)
  notifyFasterRefresh   Boolean @default(false)
  notifySms             Boolean @default(false)
  /** Relative paths under /api/uploads, e.g. referrals/<filename> — multiple allowed */
  referralImagePaths String[] @default([])
  status        String   @default("pending")
  createdAt     DateTime @default(now())

  hospital Hospital? @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  referralAnalysis AppointmentReferralAnalysis?

  @@index([userId])
  @@index([hospitalId])
  @@index([createdAt])
  @@index([status])
}

model AppointmentReferralAnalysis {
  id                   String             @id @default(uuid())
  appointmentRequestId String             @unique
  appointmentRequest   AppointmentRequest @relation(fields: [appointmentRequestId], references: [id], onDelete: Cascade)
  headline             String?
  detailsMarkdown      String?            @db.Text
  specialtyHints       String[]           @default([])
  procedureHints       String[]           @default([])
  rawEntities          String[]           @default([])
  /** Set when OpenAI extraction failed after appointment submission */
  extractionError      String?            @db.Text
  createdAt            DateTime           @default(now())

  @@index([appointmentRequestId])
}

model EzdravListing {
  id                   String   @id @default(uuid())
  routeId              String?
  serviceName          String?
  urgency              String?
  urgencyPage          String?
  region               String?
  provider             String?
  city                 String?
  postalCode           String?
  address              String?
  phone                String?
  fax                  String?
  email                String?
  website              String?
  websiteDisabled      Boolean  @default(false)
  serviceUnavailable   Boolean  @default(false)
  eOrderNotPossible    Boolean  @default(false)
  appointmentSummary   String?  @db.Text
  remarks              String?  @db.Text
  ambulances           String?  @db.Text
  lastUpdated          String?
  sourceFile           String?
  importedAt           DateTime @default(now())

  @@index([city])
  @@index([provider])
  @@index([serviceName])
  @@index([urgency])
  @@index([region])
  @@index([routeId])
}
