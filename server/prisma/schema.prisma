generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AvailabilityRequest {
  id           String   @id @default(uuid())
  need         String?
  imageUrl     String?
  locale       String?
  sessionToken String?
  createdAt    DateTime @default(now())
}

model Admin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  sessionToken String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hospitalChatSessions AdminHospitalChatSession[]
}

model AdminHospitalChatSession {
  id        String   @id @default(uuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  AdminHospitalChatMessage[]

  @@index([adminId])
}

model AdminHospitalChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  session   AdminHospitalChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([sessionId])
}

model Hospital {
  id             String            @id @default(uuid())
  name           String            @unique
  city           String?
  country        String?
  address        String?
  phone          String?
  email          String?
  website        String?
  emergency24h   Boolean?
  bedCount       Int?
  latitude       Float?
  longitude      Float?
  averageWaitDays Int?
  isActive       Boolean           @default(true)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  services       HospitalService[]
}

model HospitalService {
  id               String    @id @default(uuid())
  hospitalId       String
  specialty        String?
  procedureName    String?
  estimatedWaitDays Int?
  earliestDate     DateTime?
  isActive         Boolean   @default(true)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  hospital         Hospital  @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([hospitalId])
}
